# ============================================================
# Genzite — Shared Environment Variables
# Copy this file to .env and update values for your environment.
# ============================================================

# PostgreSQL
POSTGRES_USER=genzite_user
POSTGRES_PASSWORD=genzite_password
POSTGRES_DB=genzite_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=localhost:29092

# Auth
AUTH_BYPASS=true  # Set to false when identity-service is ready
JWT_SECRET=change-this-to-a-strong-random-secret

# AI
GEMINI_API_KEY=your-google-gemini-api-key

# AWS S3 (Media Service)
AWS_S3_BUCKET=genzite-media-dev
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
