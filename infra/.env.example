# ============================================================
# Genzite — Shared Environment Variables
# Copy this file to .env and update values for your environment.
# ============================================================

# PostgreSQL / Supabase
# If using Supabase, uncomment and fill in these two lines:
# SUPABASE_URL="postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true"
# SUPABASE_DIRECT_URL="postgresql://postgres.[ref]:[password]@[host]:5432/postgres"

# Local PostgreSQL Fallback (used if SUPABASE_URL is not set)
POSTGRES_USER=genzite_user
POSTGRES_PASSWORD=genzite_password
POSTGRES_DB=genzite_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=localhost:29092

# Auth
AUTH_BYPASS=false  # Set to false when identity-service is ready
JWT_SECRET=change-this-to-a-strong-random-secret

# AI
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
AI_DEFAULT_PROVIDER=gemini

# MCP External Servers
MCP_SERVERS='[{"name":"codebase","transport":"stdio","command":"node","args":["./node_modules/.bin/codebase-memory-mcp"]},{"name":"stitch","transport":"stdio","command":"npx","args":["-y","@anthropic/stitch-mcp"]}]'

# AWS S3 (Media Service)
AWS_S3_BUCKET=genzite-media-dev
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
