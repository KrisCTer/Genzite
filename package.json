{
  "name": "genzite",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm run dev:gateway\" \"pnpm run dev:identity\" \"pnpm run dev:site\" \"pnpm run dev:data\" \"pnpm run dev:media\" \"pnpm run dev:notification\" \"pnpm run dev:ai\" \"pnpm run dev:frontend\"",
    "build:ui": "pnpm --filter ./packages/shared-ui run build",
    "build:types": "pnpm --filter ./packages/shared-types run build",
    "build:utils": "pnpm --filter ./packages/shared-utils run build",
    "build:kafka": "pnpm --filter ./packages/kafka run build",
    "build:packages": "pnpm run build:types && pnpm run build:utils && pnpm run build:kafka",
    "dev:ui": "pnpm --filter ./packages/shared-ui run dev",
    "dev:frontend": "pnpm --filter ./apps/frontend run dev",
    "build:all": "pnpm -r run build",
    "test:all": "pnpm -r run test",
    "dev:gateway": "node scripts/dev.mjs start:dev --service gateway",
    "dev:site": "node scripts/dev.mjs start:dev --service site-service",
    "dev:data": "node scripts/dev.mjs start:dev --service data-service",
    "dev:media": "node scripts/dev.mjs start:dev --service media-service",
    "dev:notification": "node scripts/dev.mjs start:dev --service notification-service",
    "dev:ai": "node scripts/dev.mjs start:dev --service ai-service",
    "dev:identity": "node scripts/dev.mjs start:dev --service identity-service",
    "prisma:migrate": "node scripts/dev.mjs prisma migrate dev --all",
    "prisma:generate": "node scripts/dev.mjs prisma generate --all",
    "prisma:migrate:site": "node scripts/dev.mjs prisma migrate dev --service site-service",
    "prisma:migrate:data": "node scripts/dev.mjs prisma migrate dev --service data-service",
    "prisma:migrate:media": "node scripts/dev.mjs prisma migrate dev --service media-service",
    "prisma:migrate:notification": "node scripts/dev.mjs prisma migrate dev --service notification-service",
    "prisma:migrate:ai": "node scripts/dev.mjs prisma migrate dev --service ai-service",
    "prisma:migrate:identity": "node scripts/dev.mjs prisma migrate dev --service identity-service",
    "prisma:studio:site": "node scripts/dev.mjs prisma studio --service site-service",
    "prisma:studio:data": "node scripts/dev.mjs prisma studio --service data-service",
    "prisma:studio:media": "node scripts/dev.mjs prisma studio --service media-service",
    "prisma:studio:notification": "node scripts/dev.mjs prisma studio --service notification-service",
    "prisma:studio:ai": "node scripts/dev.mjs prisma studio --service ai-service",
    "prisma:studio:identity": "node scripts/dev.mjs prisma studio --service identity-service"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
